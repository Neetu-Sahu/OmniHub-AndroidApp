<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/music"
    tools:context=".Sixteenth">

    <!-- Floating Sticker 1 -->
    <ImageView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="30dp"
        android:layout_marginTop="30dp"
        android:alpha="0.3"
        android:src="@android:drawable/btn_star_big_on"
        app:tint="@color/accent_cyan" />

    <!-- Floating Sticker 2 -->
    <ImageView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="100dp"
        android:alpha="0.3"
        android:src="@android:drawable/ic_lock_silent_mode_off"
        app:tint="@color/accent_cyan" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="20dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            app:tint="@color/accent_cyan" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="MUSIC PLAYER"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold|italic" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:text="Feel the Beat"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:textStyle="italic" />

        <Button
            android:id="@+id/button40"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:layout_marginBottom="20dp"
            android:drawableStart="@android:drawable/ic_media_play"
            android:paddingStart="20dp"
            android:text="Play Music"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            app:backgroundTint="@color/dark_surface"
            app:cornerRadius="30dp"
            app:strokeColor="@color/accent_cyan"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/button41"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:layout_marginBottom="40dp"
            android:drawableStart="@android:drawable/ic_media_pause"
            android:paddingStart="20dp"
            android:text="Pause Music"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            app:backgroundTint="@color/dark_surface"
            app:cornerRadius="30dp"
            app:strokeColor="@color/accent_cyan"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/button42"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="Back"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            app:backgroundTint="@color/red"
            app:cornerRadius="30dp" />

    </LinearLayout>

</RelativeLayout>
