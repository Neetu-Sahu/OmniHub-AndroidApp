<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".Question5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:text="QUESTION 5"
        android:textColor="@color/accent_cyan"
        android:textSize="24sp"
        android:textStyle="bold|italic" />

    <TextView
        android:id="@+id/textViewQuestion5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:gravity="center"
        android:text="Who is known as the Father of the Nation (India)?"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold|italic" />

    <RadioGroup
        android:id="@+id/rg5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:background="#1AFFFFFF"
        android:padding="20dp">

        <RadioButton
            android:id="@+id/rb5_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subhash Chandra Bose"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:buttonTint="@color/accent_cyan" />

        <RadioButton
            android:id="@+id/rb5_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jawaharlal Nehru"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:buttonTint="@color/accent_cyan" />

        <RadioButton
            android:id="@+id/rb5_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mahatma Gandhi"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:buttonTint="@color/accent_cyan" />

        <RadioButton
            android:id="@+id/rb5_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sardar Patel"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:buttonTint="@color/accent_cyan" />
    </RadioGroup>

    <Button
        android:id="@+id/button55"
        android:layout_width="250dp"
        android:layout_height="60dp"
        android:text="FINISH QUIZ"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold|italic"
        app:backgroundTint="@color/accent_cyan"
        app:cornerRadius="30dp" />

</LinearLayout>
